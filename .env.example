# Stagenet RPC URL (get from contract.dev dashboard)
STAGENET_RPC_URL=https://your-stagenet-url-here.contract.dev

# Private key for deployment (use wallet generator from Stagenet)
PRIVATE_KEY=your_private_key_here

# Deployed JIT contract address (after deployment)
JIT_CONTRACT_ADDRESS=

# Etherscan API key (optional, for verification)
ETHERSCAN_API_KEY=
